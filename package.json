{
  "name": "emdash-notion",
  "private": true,
  "description": "Sync Notion pages into EmDash CMS as Portable Text via webhooks — a monorepo of native EmDash plugins (Notion → EmDash)",
  "homepage": "https://github.com/kjfsm/emdash-notion#readme",
  "bugs": {
    "url": "https://github.com/kjfsm/emdash-notion/issues"
  },
  "license": "MIT",
  "author": "kjfsm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kjfsm/emdash-notion.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "oxlint --ignore-pattern '*.astro' . && eslint .",
    "lint:fix": "oxlint --ignore-pattern '*.astro' --fix . && eslint . --fix",
    "format": "oxfmt . && prettier --write \"**/*.astro\"",
    "format:check": "oxfmt --check . && prettier --check \"**/*.astro\"",
    "knip": "knip",
    "publint": "pnpm -r --if-present publint",
    "attw": "pnpm -r --if-present attw",
    "size": "pnpm -r --if-present size",
    "changeset": "changeset",
    "version": "changeset version && pnpm -r --if-present gen-version",
    "version:snapshot": "changeset version --snapshot canary && pnpm -r --if-present gen-version",
    "release": "pnpm -r build && changeset publish",
    "release:snapshot": "changeset publish --tag canary --no-git-tag",
    "release:local": "pnpm -r --if-present run release:local"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.31.0",
    "@emdash-cms/plugin-cli": "^0.6.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-astro": "^3.0.0",
    "eslint-plugin-oxlint": "catalog:",
    "knip": "^6.25.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "^3.9.1",
    "prettier-plugin-astro": "^0.14.1",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
