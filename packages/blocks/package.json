{
  "name": "@emdash-notion/blocks",
  "version": "0.1.1",
  "description": "Notion 固有ブロック（callout/toggle/to_do）を Notion 風の見た目で描画する EmDash native プラグイン",
  "keywords": [
    "astro",
    "cms",
    "emdash",
    "emdash-plugin",
    "notion",
    "portable-text"
  ],
  "homepage": "https://github.com/kjfsm/emdash-notion#readme",
  "bugs": {
    "url": "https://github.com/kjfsm/emdash-notion/issues"
  },
  "license": "MIT",
  "author": "kjfsm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kjfsm/emdash-notion.git",
    "directory": "packages/blocks"
  },
  "files": [
    "dist",
    "src/astro",
    "src/*.astro"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./notion-color": {
      "types": "./dist/notion-color.d.mts",
      "import": "./dist/notion-color.mjs"
    },
    "./safe-url": {
      "types": "./dist/safe-url.d.mts",
      "import": "./dist/safe-url.mjs"
    },
    "./astro": "./src/astro/index.ts",
    "./NotionBookmark.astro": "./src/NotionBookmark.astro",
    "./NotionCallout.astro": "./src/NotionCallout.astro",
    "./NotionDivider.astro": "./src/NotionDivider.astro",
    "./NotionEquation.astro": "./src/NotionEquation.astro",
    "./NotionToggle.astro": "./src/NotionToggle.astro",
    "./NotionTodo.astro": "./src/NotionTodo.astro"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "gen-version": "node ../../scripts/gen-version.mjs",
    "prebuild": "pnpm gen-version",
    "build": "tsdown src/index.ts src/notion-color.ts src/safe-url.ts --dts.eager",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only --exclude-entrypoints astro NotionBookmark.astro NotionCallout.astro NotionDivider.astro NotionEquation.astro NotionToggle.astro NotionTodo.astro",
    "size": "size-limit",
    "release:local": "npm publish --no-provenance"
  },
  "devDependencies": {
    "@emdash-notion/sync": "workspace:*",
    "emdash": ">=0.28.1"
  },
  "peerDependencies": {
    "emdash": ">=0.28.1"
  },
  "engines": {
    "node": ">=20"
  }
}
