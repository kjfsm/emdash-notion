---
export interface Props {
  node: {
    _key: string;
    databaseId: string;
    title: string;
  };
}

const { node } = Astro.props;
---

<!-- Notion API はリンク先の emdash 上の URL を返さないため、リンクにはせずカード表示のみ行う。 -->
<div class="notion-child-database" data-notion-database-id={node.databaseId}>
  <span class="notion-child-database__icon" aria-hidden="true">🗄️</span>
  <span class="notion-child-database__title">{node.title}</span>
</div>

<style>
  .notion-child-database {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid #e3e2e0;
    border-radius: 6px;
    margin: 0.5rem 0;
  }

  .notion-child-database__title {
    font-weight: 500;
  }
</style>
