---
export interface Props {
  node: {
    _key: string;
    expression: string;
  };
}

const { node } = Astro.props;
---

<pre class="notion-equation"><code>{node.expression}</code></pre>

<style>
  .notion-equation {
    overflow-x: auto;
    padding: 0.75rem 1rem;
    background: #f7f6f5;
    border-radius: 4px;
    margin: 1rem 0;
    font-family: ui-monospace, monospace;
  }
</style>
