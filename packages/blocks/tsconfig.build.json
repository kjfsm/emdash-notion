{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2023"],
    "declaration": true,
    "outDir": "dist",
    "types": []
  },
  "include": ["src/index.ts"],
  "exclude": ["node_modules", "dist", "tests/**/*", "src/astro/**/*", "src/*.astro"]
}
