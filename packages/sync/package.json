{
  "name": "@emdash-notion/sync",
  "version": "0.3.1",
  "description": "Sync Notion pages into EmDash CMS as Portable Text via webhooks — a sandboxed EmDash plugin (Notion → EmDash)",
  "keywords": [
    "astro",
    "cms",
    "emdash",
    "emdash-plugin",
    "headless-cms",
    "notion",
    "notion-sync",
    "portable-text"
  ],
  "homepage": "https://github.com/kjfsm/emdash-notion#readme",
  "bugs": {
    "url": "https://github.com/kjfsm/emdash-notion/issues"
  },
  "license": "MIT",
  "author": "kjfsm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kjfsm/emdash-notion.git",
    "directory": "packages/sync"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./sandbox": {
      "types": "./dist/plugin.d.mts",
      "import": "./dist/plugin.mjs"
    },
    "./portable-text": {
      "types": "./dist/portable-text/types.d.ts",
      "import": "./dist/portable-text/types.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "emdash-plugin build && tsc -p tsconfig.portable-text.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "publint": "publint --strict",
    "attw": "attw --pack . --profile esm-only",
    "size": "size-limit",
    "validate": "emdash-plugin validate",
    "release:local": "npm publish --no-provenance"
  },
  "devDependencies": {
    "@emdash-cms/blocks": ">=0.28.1",
    "@emdash-cms/plugin-cli": "^0.6.0",
    "@notionhq/client": "^5.23.0",
    "emdash": ">=0.28.1"
  },
  "peerDependencies": {
    "emdash": ">=0.28.1"
  },
  "engines": {
    "node": ">=20"
  }
}
